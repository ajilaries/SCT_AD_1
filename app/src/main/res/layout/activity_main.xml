<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Display -->
    <TextView
        android:id="@+id/resultText"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:gravity="end"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Buttons Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:columnCount="4"
        android:rowCount="5"
        android:useDefaultMargins="true">

        <!-- Row 1 -->
        <Button
            android:text="C"
            android:onClick="onClearClick"
            style="@style/CalcBtnGray"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"/>

        <Button
            android:text="%"
            android:onClick="onOperatorClick"
            style="@style/CalcBtnGray"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"/>

        <Button
            android:text="/"
            android:onClick="onOperatorClick"
            style="@style/CalcBtnOrange"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"/>

        <Button
            android:text="⌫"
            android:onClick="onBackspaceClick"
            style="@style/CalcBtnGray"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"/>

        <!-- Row 2 -->
        <Button android:text="7" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="8" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="9" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="*" android:onClick="onOperatorClick" style="@style/CalcBtnOrange"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <!-- Row 3 -->
        <Button android:text="4" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="5" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="6" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="-" android:onClick="onOperatorClick" style="@style/CalcBtnOrange"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <!-- Row 4 -->
        <Button android:text="1" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="2" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="3" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="+" android:onClick="onOperatorClick" style="@style/CalcBtnOrange"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <!-- Row 5 -->
        <Button android:text="0" android:onClick="onNumberClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button android:text="." android:onClick="onDecimalClick" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"/>

        <Button
            android:text="="
            android:onClick="onEqualClick"
            style="@style/CalcBtnEqual"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnSpan="2"
            android:layout_rowWeight="1"
            android:layout_columnWeight="2"/>

    </GridLayout>

</LinearLayout>